# Application Settings
APP_NAME=Layer1 Phase1
APP_ENV=development
DEBUG=true
VERSION=0.1.0

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/layer1_phase1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=layer1_phase1
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# LLM Provider (Week 3+)
LLM_PROVIDER=openai
OPENAI_API_KEY=your-api-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# Cost Tracking (Week 3+)
TRACK_LLM_COSTS=true
